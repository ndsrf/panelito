# ============================================================
# Panelito — Environment Variables Reference
# Copy this file to:
#   apps/web/.env.local  (Next.js)
#   apps/api/.env        (Hono)
# Then fill in values from `supabase status`
# ============================================================

# ---- Next.js (apps/web/.env.local) ----

# Supabase project URL (from `supabase status` → API URL)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Supabase anon public key (from `supabase status` → anon key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Hono API base URL
NEXT_PUBLIC_API_URL=http://localhost:8787

# ---- Hono API (apps/api/.env) ----

# Supabase project URL (same as above, server-side)
SUPABASE_URL=http://127.0.0.1:54321

# Supabase service role key (from `supabase status` → service_role key)
# WARNING: Never expose this to the browser
SUPABASE_SERVICE_ROLE_KEY=

# 32-byte hex secret for AES-256-GCM encryption of Anthropic API keys
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KEY_ENCRYPTION_SECRET=

# Port for the Hono API server
API_PORT=8787

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# ---- Supabase local OAuth (optional for Plan 02) ----

# Google OAuth credentials (create at https://console.cloud.google.com/apis/credentials)
# These must be set in your shell before running `supabase start`
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=
